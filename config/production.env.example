APP_ENV=production

POSTGRES_USER=aici
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_DB=aici

# Proje requirements.txt içinde asyncpg kullanıyor.
DATABASE_URL=postgresql+asyncpg://aici:CHANGE_ME_DATABASE_PASSWORD@db:5432/aici
REDIS_URL=redis://redis:6379/0

JWT_SECRET=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS

# Yerel production doğrulaması için:
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Host üzerinde 8000 dolu olabileceği için production API varsayılanı:
AICI_API_PORT=18000

LOG_LEVEL=INFO
TRUST_PROXY_HEADERS=true
