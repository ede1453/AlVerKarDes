APP_NAME=AI Consumer Intelligence
APP_ENV=production
DEBUG=false

DATABASE_URL=postgresql+asyncpg://postgres:replace-with-strong-postgres-password@aici-db:5432/aici
REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-with-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
INTERNAL_SERVICE_KEY=replace-with-long-random-secret

POSTGRES_PASSWORD=replace-with-strong-postgres-password

# CONNECT-004: docker-compose.prod.yml only loads .env.prod via env_file --
# vars absent from this file are never visible inside the container no
# matter what is set elsewhere. Leave *_FIXTURE_MODE=true (or blank
# credentials) to keep a connector parked in test-fixture mode.
EBAY_CLIENT_ID=CHANGE_ME
EBAY_CLIENT_SECRET=CHANGE_ME
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_BASE_URL=https://api.ebay.com
EBAY_TOKEN_URL=https://api.ebay.com/identity/v1/oauth2/token
EBAY_FIXTURE_MODE=true
# CONNECT-006: opsiyonel, virgülle ayrılmış ek eBay pazaryerleri (aynı
# client_id/secret'ı paylaşır, sadece X-EBAY-C-MARKETPLACE-ID değişir).
EBAY_ADDITIONAL_MARKETPLACES=EBAY_US,EBAY_GB
IDEALO_PARTNER_ID=CHANGE_ME
IDEALO_API_KEY=CHANGE_ME
IDEALO_MARKETPLACE=DE
IDEALO_FIXTURE_MODE=true
# CONNECT-006: Best Buy Products API -- apiKey query-param kimlik
# doğrulaması, Amazon Associates tarzı bir satış/onboarding şartı yok.
BESTBUY_API_KEY=CHANGE_ME
BESTBUY_BASE_URL=https://api.bestbuy.com/v1
BESTBUY_FIXTURE_MODE=true
